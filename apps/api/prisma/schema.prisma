// Cache local des données WhatsApp (source de vérité = WhatsApp via Baileys).
// L'état d'authentification Baileys est persisté dans un volume (fichiers), pas ici.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Comptes WhatsApp connectés (multi-compte). 'default' = compte historique unique.
model WaAccount {
  id        String   @id
  label     String
  color     String?
  phoneJid  String?  @map("phone_jid")
  status    String   @default("disconnected")
  isDefault Boolean  @default(false) @map("is_default")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("wa_accounts")
}

// Contacts / interlocuteurs connus.
model WaContact {
  accountId String   @default("default") @map("account_id")
  jid       String
  name      String?
  pushName  String?  @map("push_name")
  isGroup   Boolean  @default(false) @map("is_group")
  avatarUrl String?  @map("avatar_url")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@id([accountId, jid])
  @@map("wa_contacts")
}

// Discussions (liste de gauche).
model WaChat {
  accountId          String    @default("default") @map("account_id")
  jid                String
  name               String?
  isGroup            Boolean   @default(false) @map("is_group")
  unreadCount        Int       @default(0) @map("unread_count")
  lastMessageAt      DateTime? @map("last_message_at")
  lastMessagePreview String?   @map("last_message_preview")
  pinned             Boolean   @default(false)
  archived           Boolean   @default(false)
  muted              Boolean   @default(false)
  avatarUrl          String?   @map("avatar_url")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  @@id([accountId, jid])
  @@index([accountId, lastMessageAt])
  @@map("wa_chats")
}

// Messages (cache pour l'historique et la réactivité). Clé = (compte, chat, id WhatsApp).
model WaMessage {
  accountId  String   @default("default") @map("account_id")
  id         String // id du message WhatsApp
  chatJid    String   @map("chat_jid")
  fromMe     Boolean  @map("from_me")
  senderJid  String?  @map("sender_jid")
  senderName String?  @map("sender_name")
  type       String   @default("text")
  text       String?
  sentAt     DateTime @map("sent_at")
  status     String   @default("pending")
  quotedId   String?  @map("quoted_id")
  media      Json?
  reactions  Json?
  receipts   Json?   // accusés par destinataire: [{userJid, deliveredAt, readAt, playedAt}] (epoch ms)
  clientId   String?  @map("client_id")
  // Horodatage de la dernière édition (null si jamais édité).
  editedAt   DateTime? @map("edited_at")
  // Message brut Baileys (proto IMessage) — conservé pour (re)télécharger le média.
  rawMessage Json?    @map("raw_message")
  // SHA-256 (base64) du fichier média — sert à dédupliquer la double livraison LID.
  fileSha256 String?  @map("file_sha256")
  createdAt  DateTime @default(now()) @map("created_at")

  @@id([accountId, chatJid, id])
  @@index([accountId, chatJid, sentAt])
  @@index([accountId, chatJid, fileSha256])
  // Vue fusionnée par personne (Phase 3) : timeline cross-compte triée par date
  // (WHERE chat_jid = pn ORDER BY sent_at), sans filtre account_id en tête.
  @@index([chatJid, sentAt])
  @@map("wa_messages")
}

// Correspondance LID (identité masquée WhatsApp) -> numéro (@s.whatsapp.net).
// Apprise depuis key.senderLid/senderPn (DM) et key.participant/participantPn (groupes).
model WaLidMap {
  accountId String   @default("default") @map("account_id")
  lid       String
  pn        String
  updatedAt DateTime @updatedAt @map("updated_at")

  @@id([accountId, lid])
  @@index([accountId, pn])
  @@map("wa_lid_map")
}
