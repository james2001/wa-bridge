# =============================================================================
#  whatapp-clone — pont WhatsApp Web auto-hébergé. Copier en `.env` puis adapter.
#  NE PAS committer le vrai .env.
# =============================================================================

# --- Domaine & ports Caddy (dev: *.localhost résout vers 127.0.0.1) ---
APP_DOMAIN=app.localhost
# Laisser 80/443 si libres. Sinon (autre reverse proxy), choisir des ports libres
# (ex: 8444/8553) et accéder via https://app.localhost:<HTTPS_PORT>.
HTTP_PORT=80
HTTPS_PORT=443

# --- Accès à l'app (mot de passe qui protège le pont) ---
APP_PASSWORD=change_me_app_password

# --- PostgreSQL (cache des chats/messages) ---
POSTGRES_USER=whatapp
POSTGRES_PASSWORD=devpassword_change_me
POSTGRES_DB=whatapp
DATABASE_URL=postgresql://whatapp:devpassword_change_me@postgres:5432/whatapp?schema=public

# --- JWT (générer: openssl rand -hex 32) ---
JWT_ACCESS_SECRET=dev_access_secret_change_me_min_32_characters_long
JWT_REFRESH_SECRET=dev_refresh_secret_change_me_min_32_characters_long
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# --- Session WhatsApp (Baileys) ---
# Répertoire (volume) où est persistée la session WhatsApp. ⚠ SENSIBLE.
WA_AUTH_DIR=/data/wa-auth

# --- Backend ---
NODE_ENV=development
API_PORT=3000
CORS_ORIGINS=https://app.localhost

# --- Accès Agent/LLM (server-to-server) ---
# API dédiée aux intégrations automatisées (agents, LLM), distincte de l'accès
# humain (JWT). Auth par clé statique dans le header X-API-Key.
# Clé d'API. VIDE => API agent DÉSACTIVÉE (fail-closed). Générer une clé forte:
#   openssl rand -hex 32
AGENT_API_KEY=
# Autoriser l'ÉCRITURE (envoi de texte) via l'agent. Défaut: false (lecture seule).
AGENT_WRITE_ENABLED=false
# Autoriser l'envoi de MÉDIA via l'agent. Défaut: false.
AGENT_ALLOW_MEDIA=false
# Allow-list de comptes autorisés (CSV). Vide => aucune restriction de compte.
AGENT_ACCOUNT_ALLOWLIST=
# Allow-list de discussions autorisées par JID (CSV). Vide => aucune restriction.
AGENT_CHAT_ALLOWLIST=

# --- Frontend (injecté par Vite au build) ---
VITE_API_BASE_URL=/api
# Vide => socket same-origin (suit automatiquement l'hôte:port de la page).
VITE_SOCKET_URL=
